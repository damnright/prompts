  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /etc/claude-code/hooks/pretooluse-guard.py"
          }
        ]
      }
    ]
  }
